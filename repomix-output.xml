<file path="css/hero.css">
.hero {
    min-height: calc(100vh - 92px); background-color: var(--primary-dark); 
    color: white; display: flex; flex-direction: column; justify-content: center;
    align-items: center; text-align: center; padding: clamp(2rem, 5vw, 4rem);
    position: relative; overflow: hidden; 
}

.hero-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; background-color: var(--primary-dark); display: block; }

.hero h1, .hero p, .hero .scroll-indicator { z-index: 2; text-shadow: 0 2px 10px rgba(0,0,0,0.5); }

.hero-small {
    height: clamp(300px, 35vh, 450px); min-height: 300px; justify-content: flex-end;
    padding-bottom: clamp(2rem, 6vw, 4rem); background-color: var(--primary-dark);
}

.theme-chem.hero-small { background: linear-gradient(135deg, var(--primary-dark) 40%, rgba(var(--chem-rgb), 0.85)); box-shadow: 0 10px 40px rgba(var(--chem-rgb), 0.4); }
.theme-bio.hero-small { background: linear-gradient(135deg, var(--primary-dark) 40%, rgba(var(--bio-rgb), 0.85)); box-shadow: 0 10px 40px rgba(var(--bio-rgb), 0.4); }
.theme-phys.hero-small { background: linear-gradient(135deg, var(--primary-dark) 40%, rgba(var(--phys-rgb), 0.85)); box-shadow: 0 10px 40px rgba(var(--phys-rgb), 0.4); }
.theme-math.hero-small { background: linear-gradient(135deg, var(--primary-dark) 40%, rgba(var(--math-rgb), 0.85)); box-shadow: 0 10px 40px rgba(var(--math-rgb), 0.4); }
.theme-eng.hero-small { background: linear-gradient(135deg, var(--primary-dark) 40%, rgba(var(--eng-rgb), 0.85)); box-shadow: 0 10px 40px rgba(var(--eng-rgb), 0.4); }
.theme-soc.hero-small  { background: linear-gradient(135deg, var(--primary-dark) 40%, rgba(var(--soc-rgb),  0.85)); box-shadow: 0 10px 40px rgba(var(--soc-rgb),  0.4); }

.hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem); margin-bottom: clamp(0.5rem, 2vw, 1rem);
    background: linear-gradient(90deg, #ff416c, #f7b733, #00b09b); 
    background-size: 200% auto; background-clip: text; -webkit-background-clip: text;
    -webkit-text-fill-color: transparent; transition: background-position 0.4s ease-in-out;
    cursor: default; line-height: 1.2;
}

.hero h1:hover { background-position: 100% center; }
