<file path="games/chemistry/intermediate/solution-strategist/style.css">
:root {
    --bg-color: #f1f5f9;
    --card-bg: #ffffff;
    --text-dark: #334155;
    --subject-primary: #0284c7;
    --subject-hover: #0369a1;
    --primary: #0284c7;
    --border-color: #e2e8f0;
    --danger: #ef4444;
    --success: #10b981;
    --shadow: 0 4px 6px rgba(0,0,0,0.1);
    --bench-color: #cbd5e1;
}

.dark-theme {
    --bg-color: #0f172a;
    --card-bg: #1e293b;
    --text-dark: #f8fafc;
    --subject-primary: #38bdf8;
    --subject-hover: #0ea5e9;
    --primary: #38bdf8;
    --border-color: #334155;
    --bench-color: #334155;
}

body { background-color: var(--bg-color); }

.game-container {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; padding: 2rem 1rem; 
    max-width: 900px; margin: 0 auto; width: 100%;
}

.crisis-panel {
    background: var(--card-bg); padding: 2rem; border-radius: 12px;
    box-shadow: var(--shadow); width: 100%; margin-bottom: 2rem;
    border: 2px solid var(--border-color); border-top: 6px solid var(--primary);
    position: relative;
}

.scenario-header {
    color: var(--primary); font-weight: 800; text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;
}

.scenario-text { font-size: 1.2rem; line-height: 1.6; margin-bottom: 1.5rem; font-weight: 600; }

/* Interactive Lab Bench */
.lab-bench {
    position: relative; width: 100%; height: 260px;
    background: linear-gradient(180deg, transparent 80%, var(--bench-color) 80%, var(--bench-color) 100%);
    display: flex; justify-content: center; align-items: flex-end; padding-bottom: 52px;
    margin-bottom: 2rem; border-radius: 8px; overflow: hidden;
}

.beaker-container {
    position: relative; width: 140px; height: 180px;
}

.beaker {
    position: absolute; bottom: 0; left: 0; width: 100%; height: 100%;
    border: 6px solid rgba(148, 163, 184, 0.5); border-top: none;
    border-radius: 0 0 16px 16px; background: rgba(255,255,255,0.05);
    box-shadow: inset 0 -10px 20px rgba(0,0,0,0.1);
    overflow: hidden; z-index: 2;
}

.liquid {
    position: absolute; bottom: 0; left: 0; width: 100%; height: 0%;
    background-color: rgba(56, 182, 255, 0.2);
    transition: height 0.3s ease-out, background-color 0.4s ease-out;
    border-top: 2px solid rgba(255,255,255,0.4);
}

.markings {
    position: absolute; top: 0; left: 10px; height: 100%; width: 20px;
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 10px 0; z-index: 3; opacity: 0.5;
}

.mark { border-bottom: 2px solid var(--text-dark); width: 15px; height: 1px; }

/* Fluid Flow Animation */
.fluid-stream {
    position: absolute; top: -80px; left: 50%; transform: translateX(-50%);
    width: 12px; height: 0; background: rgba(168, 216, 234, 0.6);
    border-radius: 6px; z-index: 1; opacity: 0; transition: opacity 0.2s;
}

.fluid-stream.pouring {
    height: 100px; opacity: 1;
    animation: pour 0.5s infinite linear;
}

@keyframes pour {
    0% { background-position: 0 0; }
    100% { background-position: 0 20px; }
}

/* Precipitation Crystals */
.crystals {
    position: absolute; bottom: 5px; left: 5px; right: 5px; height: 30px;
    display: flex; flex-wrap: wrap; justify-content: space-around;
    align-content: flex-end; z-index: 3; opacity: 0; transition: opacity 0.3s;
}

.crystal {
    width: 6px; height: 6px; background: rgba(255,255,255,0.9);
    transform: rotate(45deg); margin: 2px;
    animation: sparkle 1.5s infinite alternate;
}

@keyframes sparkle {
    0% { transform: scale(0.8) rotate(45deg); opacity: 0.7; }
    100% { transform: scale(1.2) rotate(45deg); opacity: 1; }
}

/* Controls */
.controls-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;
}

.control-group {
    background: var(--details-bg, #f8fafc); padding: 1.5rem; border-radius: 8px;
    border: 1px solid var(--border-color); text-align: center;
}

.control-group label {
    display: block; font-weight: 700; margin-bottom: 1rem; color: var(--text-dark);
}

input[type="range"] {
    width: 100%; accent-color: var(--primary); cursor: pointer;
}

.control-value {
    display: block; margin-top: 0.5rem; font-size: 1.1rem; font-weight: 600; color: var(--primary);
}

/* Reference Panel */
.reference-panel {
    background: var(--details-bg, #f8fafc); border-radius: 8px;
    border: 1px solid var(--border-color); margin-bottom: 1.5rem;
}

.reference-panel summary {
    padding: 1rem; font-weight: 700; cursor: pointer; color: var(--subject-primary);
    list-style: none; display: flex; justify-content: space-between; align-items: center;
}

.reference-panel summary::-webkit-details-marker { display: none; }
.reference-panel summary::after { content: '+'; font-size: 1.2rem; }
.reference-panel[open] summary::after { content: '-'; }

.ref-content {
    padding: 1rem; border-top: 1px solid var(--border-color); font-size: 0.95rem; line-height: 1.6;
}

/* Diagnostic Feedback Overlay */
.diagnostic-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.8); border-radius: 10px; display: none;
    flex-direction: column; align-items: center; justify-content: center;
    color: white; z-index: 10; padding: 2rem; text-align: center;
    backdrop-filter: blur(3px); animation: fadeIn 0.3s ease-out;
}

.diagnostic-overlay.active { display: flex; }
.diagnostic-title { color: var(--danger); font-size: 1.5rem; font-weight: 800; margin-bottom: 1rem; }
.diagnostic-message { font-size: 1.1rem; margin-bottom: 1.5rem; }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

@media (max-width: 600px) {
    .controls-grid { grid-template-columns: 1fr; gap: 1rem; }
}
</file>

