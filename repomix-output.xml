:root {
    --bg-color: #f8fafc;
    --card-bg: #ffffff;
    --text-dark: #334155;
    --subject-primary: #0f766e; 
    --subject-hover: #115e59;
    --primary: #0f766e;
    --border-color: #cbd5e1;
    --warning: #ea580c; 
    --danger: #ef4444;
    --success: #10b981;
    --shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.dark-theme {
    --bg-color: #0f172a;
    --card-bg: #1e293b;
    --text-dark: #f8fafc;
    --subject-primary: #14b8a6;
    --subject-hover: #0d9488;
    --primary: #14b8a6;
    --border-color: #334155;
    --warning: #f97316;
}

body { background-color: var(--bg-color); }
.game-header { border-bottom: 4px solid var(--warning); }
.game-header h1 { letter-spacing: 1px; }

.game-container {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; padding: 3rem 1rem; max-width: 850px; margin: 0 auto; width: 100%;
}

.reactor-panel {
    background: var(--card-bg); padding: 2.5rem; border-radius: 12px;
    box-shadow: var(--shadow); width: 100%; margin-bottom: 2rem;
    border: 2px solid var(--border-color); position: relative; overflow: hidden;
}

.reactor-panel::before {
    content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 6px;
    background: repeating-linear-gradient(45deg, var(--warning), var(--warning) 10px, transparent 10px, transparent 20px);
}

.reactor-header {
    color: var(--warning); font-weight: 800; text-transform: uppercase;
    letter-spacing: 1.5px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;
}

.reactor-text { font-size: 1.2rem; line-height: 1.6; margin-bottom: 2rem; }

.reaction-display {
    background: rgba(15, 118, 110, 0.1); border: 1px solid var(--primary);
    padding: 1rem; border-radius: 8px; text-align: center;
    font-size: 1.3rem; font-weight: 600; margin-bottom: 2rem; color: var(--primary);
}
.dark-theme .reaction-display { background: rgba(20, 184, 166, 0.1); }

.options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

.option-btn {
    background: var(--card-bg); border: 2px solid var(--border-color);
    color: var(--text-dark); padding: 1.25rem 1rem; border-radius: 8px;
    font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.2s;
    display: flex; align-items: center; justify-content: center; text-align: center;
}

@media (hover: hover) {
    .option-btn:hover:not(:disabled) {
        border-color: var(--primary); background: var(--primary); color: white;
        transform: translateY(-2px); box-shadow: 0 4px 10px rgba(15, 118, 110, 0.2);
    }
}

.option-btn.correct { background: var(--success); border-color: var(--success); color: white; transform: none; box-shadow: none; }
.option-btn.wrong { background: var(--danger); border-color: var(--danger); color: white; animation: shake 0.3s; transform: none; box-shadow: none; }
.option-btn:disabled { cursor: not-allowed; opacity: 0.8; }

@keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    50% { transform: translateX(6px); }
    75% { transform: translateX(-6px); }
}

@media (max-width: 650px) {
    .options-grid { grid-template-columns: 1fr; }
    .back-btn { position: static; display: inline-block; margin-bottom: 1rem; }
}
