<file path="games/chemistry/advanced/equilibrium-engine/style.css">
:root {
    --bg-color: #0b1120;
    --card-bg: #1e293b;
    --text-dark: #f8fafc;
    --subject-primary: #10b981; 
    --subject-hover: #059669;
    --primary: #10b981;
    --border-color: #334155;
    --warning: #f59e0b; 
    --danger: #ef4444;
    --success: #10b981;
    --shadow: 0 4px 15px rgba(0,0,0,0.5);
    --reactor-glow: rgba(16, 185, 129, 0.2);
}

body { background-color: var(--bg-color); color: var(--text-dark); }
.game-header { border-bottom: 4px solid var(--primary); background-color: #020617; }
.game-header h1 { font-family: 'Share Tech Mono', monospace; color: var(--primary); letter-spacing: 2px; }

.game-container {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; padding: 2rem 1rem; 
    max-width: 950px; margin: 0 auto; width: 100%;
}

.engine-panel {
    background: var(--card-bg); padding: 2rem; border-radius: 12px;
    box-shadow: var(--shadow); width: 100%; margin-bottom: 2rem;
    border: 2px solid var(--border-color); border-top: 6px solid var(--primary);
    position: relative; overflow: hidden;
}

.engine-header {
    color: var(--primary); font-weight: 800; text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;
}

/* Visualization Area */
.reactor-dashboard {
    display: flex; gap: 2rem; align-items: center; justify-content: space-between;
    background: #020617; padding: 2rem; border-radius: 12px;
    border: 2px solid #334155; margin-bottom: 2rem;
}

@media (max-width: 768px) {
    .reactor-dashboard { flex-direction: column; }
}

/* Reactor Core */
.reactor-core-wrapper {
    position: relative; width: 220px; height: 220px; margin: 0 auto;
}

.reactor-glass {
    position: absolute; inset: 0; border-radius: 50%;
    border: 6px solid #475569; background: rgba(15, 23, 42, 0.8);
    box-shadow: inset 0 0 40px var(--reactor-glow), 0 0 20px var(--reactor-glow);
    overflow: hidden; z-index: 2; transition: all 0.5s ease;
}

.particle-canvas {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
    border-radius: 50%;
}

/* Q vs K Gauges */
.gauges-panel {
    display: flex; gap: 2rem; justify-content: center;
}

.gauge-container {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
}

.gauge-track {
    width: 40px; height: 160px; background: #0f172a;
    border: 2px solid #475569; border-radius: 20px;
    position: relative; overflow: hidden;
    box-shadow: inset 0 4px 10px rgba(0,0,0,0.6);
}

.gauge-fill {
    position: absolute; bottom: 0; left: 0; width: 100%;
    border-radius: 20px; transition: height 0.5s ease-out, background-color 0.3s;
}

.fill-q { background: linear-gradient(0deg, #3b82f6, #60a5fa); height: 50%; }
.fill-k { background: linear-gradient(0deg, #10b981, #34d399); height: 50%; }

.gauge-label {
    font-family: 'Share Tech Mono', monospace; font-size: 1.2rem;
    font-weight: bold; color: #cbd5e1;
}

/* Data Readout */
.data-readout {
    background: rgba(16, 185, 129, 0.1); border: 1px dashed var(--primary);
    padding: 1rem 1.5rem; border-radius: 8px; font-size: 1.2rem;
    text-align: center; margin-bottom: 2rem;
}

.data-readout .equation { font-weight: 800; color: var(--text-dark); margin-bottom: 0.5rem; font-size: 1.3rem; }
.data-readout .enthalpy { color: #94a3b8; font-family: 'Share Tech Mono', monospace; }

/* Prompt & Options */
.scenario-prompt { font-size: 1.15rem; line-height: 1.6; margin-bottom: 1.5rem; font-weight: 600; }

.options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

.option-btn {
    background: var(--card-bg); border: 2px solid var(--border-color);
    color: var(--text-dark); padding: 1.25rem 1rem; border-radius: 8px;
    font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.2s;
    display: flex; align-items: center; justify-content: center; text-align: center;
}

@media (hover: hover) {
    .option-btn:hover:not(:disabled) {
        border-color: var(--primary); background: var(--primary); color: #020617;
        transform: translateY(-2px); box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }
}

.option-btn.correct { background: var(--success); border-color: var(--success); color: #020617; transform: none; box-shadow: 0 0 15px rgba(16,185,129,0.5); }
.option-btn.wrong { background: var(--danger); border-color: var(--danger); color: white; animation: shake 0.3s; transform: none; box-shadow: 0 0 15px rgba(239,68,68,0.5); }
.option-btn:disabled { cursor: not-allowed; opacity: 0.7; }

@keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    50% { transform: translateX(6px); }
    75% { transform: translateX(-6px); }
}

@media (max-width: 650px) {
    .options-grid { grid-template-columns: 1fr; }
}

/* Dynamic State Classes */
.state-hot .reactor-glass { box-shadow: inset 0 0 40px rgba(239,68,68,0.3), 0 0 20px rgba(239,68,68,0.3); border-color: #7f1d1d; }
.state-cold .reactor-glass { box-shadow: inset 0 0 40px rgba(56,182,255,0.3), 0 0 20px rgba(56,182,255,0.3); border-color: #0c4a6e; }
.state-pressure .reactor-glass { transform: scale(0.9); border-width: 8px; }
.state-stabilized .reactor-glass { box-shadow: inset 0 0 60px rgba(16,185,129,0.5), 0 0 30px rgba(16,185,129,0.5); border-color: #065f46; }
</file>

