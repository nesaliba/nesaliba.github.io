}

.control-group { margin-bottom: 1.5rem; }
.control-group h3 { color: var(--text-dark); margin-bottom: 1rem; font-size: 1.1rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; }

.mode-buttons { display: flex; flex-direction: column; gap: 0.5rem; }
.btn-mode { padding: 0.75rem; border: 1px solid var(--border-color); background: var(--bg-color); color: var(--text-dark); border-radius: 4px; cursor: pointer; font-weight: 600; transition: all 0.2s; text-align: left; }
.btn-mode:hover { background: #e2e8f0; }
body.dark-theme .btn-mode:hover { background: #334155; }
.btn-mode.active { background: var(--subject-primary); color: white; border-color: var(--subject-primary); }

.monitor-container {
