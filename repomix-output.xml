.cards-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); 
    gap: 2rem; 
    padding: 1rem 0; 
    width: 100%; 
}

.card {
    background: var(--card-bg); border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    transition: transform 0.3s, box-shadow 0.3s; text-decoration: none; color: inherit; display: flex;
    flex-direction: column; height: 100%;
}
.card:hover { transform: translateY(-5px); }

.card.chem:hover { box-shadow: 0 10px 25px rgba(var(--chem-rgb), 0.4); }
.card.bio:hover { box-shadow: 0 10px 25px rgba(var(--bio-rgb), 0.4); }
.card.phys:hover { box-shadow: 0 10px 25px rgba(var(--phys-rgb), 0.4); }
.card.math:hover { box-shadow: 0 10px 25px rgba(var(--math-rgb), 0.4); }
.card.eng:hover { box-shadow: 0 10px 25px rgba(var(--eng-rgb), 0.4); }
.card.soc:hover  { box-shadow: 0 10px 25px rgba(var(--soc-rgb),  0.4); }

.card-header { height: 120px; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem; font-weight: bold; }
.card-body { padding: 1.5rem; flex-grow: 1; }
.card-body h3 { margin-bottom: 0.5rem; font-size: clamp(1.1rem, 1.5vw, 1.3rem); }

.card.chem .card-header { background-color: var(--chem-color); }
.card.bio .card-header { background-color: var(--bio-color); }
.card.phys .card-header { background-color: var(--phys-color); }
