<file path="games/chemistry/advanced/titration-tower/style.css">
:root {
    --bg-color: #0d1117;
    --card-bg: #161b22;
    --text-dark: #c9d1d9;
    --subject-primary: #39ff14;
    --subject-hover: #21a309;
    --primary: #39ff14;
    --border-color: #30363d;
    --danger: #ef4444;
    --success: #10b981;
    --shadow: 0 4px 10px rgba(0,0,0,0.5);
    
    --crt-bg: #050a05;
    --crt-grid: #0d220d;
}

body { background-color: var(--bg-color); color: var(--text-dark); }
.game-header { border-bottom: 4px solid var(--subject-primary); background-color: #000; }
.game-header h1 { font-family: 'Share Tech Mono', monospace; color: var(--subject-primary); letter-spacing: 2px; }

.game-container {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; padding: 2rem 1rem; 
    max-width: 1000px; margin: 0 auto; width: 100%;
}

.tower-panel {
    background: var(--card-bg); padding: 2rem; border-radius: 12px;
    box-shadow: var(--shadow); width: 100%; margin-bottom: 2rem;
    border: 2px solid var(--border-color);
    position: relative; overflow: hidden;
}

.tower-header {
    color: var(--text-dark); font-weight: 800; text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;
}

.tower-ui {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 1.5rem;
    width: 100%;
}

@media (max-width: 800px) {
    .tower-ui { grid-template-columns: 1fr; }
}

/* CRT Monitor */
.monitor-panel {
    background: var(--crt-bg);
    border: 4px solid #333;
    border-radius: 12px;
    position: relative;
    box-shadow: inset 0 0 25px rgba(0, 0, 0, 0.8);
    display: flex; flex-direction: column;
    padding: 1rem;
}

.crt-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
    background-size: 100% 4px, 6px 100%;
    pointer-events: none; z-index: 5;
}

#curve-canvas { width: 100%; height: 300px; z-index: 2; position: relative; }
.monitor-text { font-family: 'Share Tech Mono', monospace; color: var(--primary); font-size: 0.9rem; text-align: center; margin-top: 0.5rem; }

/* Lab Bench */
.bench-panel { display: flex; flex-direction: column; gap: 1.5rem; }

.vials-container {
    display: flex; justify-content: space-around;
    background: #000; padding: 1rem; border-radius: 8px; border: 1px solid #333;
}

.vial-wrapper { display: flex; flex-direction: column; align-items: center; gap: 5px; }

.vial-glass {
    width: 20px; height: 50px; border: 2px solid rgba(255, 255, 255, 0.4);
    border-radius: 0 0 10px 10px; border-top: none;
    background: rgba(255,255,255,0.05); position: relative; overflow: hidden;
}

.vial-liquid {
    position: absolute; bottom: 0; width: 100%; height: 75%;
    transition: background-color 0.2s;
}

.vial-label { font-size: 0.7rem; text-align: center; color: #8b949e; max-width: 60px; line-height: 1.2; }

.flask-assembly { margin: 0 auto; padding: 1rem; text-align: center; background: #000; border-radius: 8px; border: 1px solid #333; position: relative; }
.flask-neck { width: 20px; height: 25px; border-left: 3px solid rgba(255,255,255,0.6); border-right: 3px solid rgba(255,255,255,0.6); margin: 0 auto; }
.flask-glass {
    width: 80px; height: 80px; border: 3px solid rgba(255,255,255,0.6); border-radius: 50%;
    margin: 0 auto; position: relative; overflow: hidden; top: -3px; background: rgba(255,255,255,0.05);
}
.flask-liquid { position: absolute; bottom: 0; width: 100%; height: 50%; transition: background-color 0.2s; }

/* Controls */
.controls-panel {
    background: #000; padding: 1rem; border-radius: 8px; border: 1px solid #333;
}

.info-readout {
    font-family: 'Share Tech Mono', monospace; 
    font-size: 1.25rem; 
    color: #e6edf3; 
    margin-bottom: 1.5rem; 
    padding-bottom: 1rem; 
    border-bottom: 1px solid #333;
    line-height: 1.5;
}
.info-readout span { color: var(--primary); font-weight: bold; }

.titrant-buttons { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }
.titrant-buttons button {
    flex: 1; padding: 0.75rem; background: #21262d; border: 1px solid #30363d;
    color: #c9d1d9; border-radius: 6px; font-weight: 600; cursor: pointer; transition: all 0.2s;
}
.titrant-buttons button:hover:not(:disabled) { background: #30363d; border-color: #8b949e; }
.titrant-buttons button:disabled { opacity: 0.5; cursor: not-allowed; }

.submit-section { display: flex; flex-direction: column; gap: 0.5rem; }
.input-ca {
    padding: 0.75rem; background: #0d1117; border: 1px solid #30363d; color: var(--primary);
    border-radius: 6px; font-family: 'Share Tech Mono', monospace; font-size: 1.1rem; text-align: center;
}
.input-ca:focus { outline: none; border-color: var(--primary); }

.btn-submit {
    padding: 1rem; background: var(--subject-primary); color: #000; border: none;
    border-radius: 6px; font-weight: 800; text-transform: uppercase; cursor: pointer; transition: background 0.2s;
}
.btn-submit:hover:not(:disabled) { background: var(--subject-hover); }
.btn-submit:disabled { background: #30363d; color: #8b949e; cursor: not-allowed; }

.btn-hint {
    margin-top: 1rem; width: 100%; padding: 0.5rem; background: transparent;
    border: 1px dashed #8b949e; color: #8b949e; border-radius: 4px; cursor: pointer; transition: all 0.2s;
}
.btn-hint:hover:not(:disabled) { color: #f1e05a; border-color: #f1e05a; }

.hint-display { margin-top: 0.5rem; font-size: 0.85rem; color: #f1e05a; min-height: 1.5em; text-align: center; }

/* Structural Damage & Diagnostics */
@keyframes shake-tower {
    0% { transform: translate(0, 0) rotate(0); }
    20% { transform: translate(-8px, 4px) rotate(-1deg); }
    40% { transform: translate(8px, -4px) rotate(1deg); }
    60% { transform: translate(-8px, -4px) rotate(0); }
    80% { transform: translate(8px, 4px) rotate(-1deg); }
    100% { transform: translate(0, 0) rotate(0); }
}
.shake-tower { animation: shake-tower 0.4s ease-in-out; }
.flash-flask { filter: brightness(3) contrast(1.5); box-shadow: 0 0 20px rgba(255,0,0,0.8); }

.diagnostic-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.9); display: none; flex-direction: column;
    align-items: center; justify-content: center; z-index: 100;
    padding: 2rem; text-align: center; backdrop-filter: blur(4px);
    animation: fadeIn 0.3s ease-out;
}
.diagnostic-overlay.active { display: flex; }
.diagnostic-title { font-family: 'Share Tech Mono', monospace; font-size: 1.8rem; font-weight: 800; margin-bottom: 1rem; }
.diagnostic-message { font-size: 1.1rem; margin-bottom: 1.5rem; line-height: 1.5; max-width: 500px; color: #c9d1d9; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
