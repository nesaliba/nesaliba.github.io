:root {
    --bg-color: #e0e7ff;
    --header-color: #c4b5fd;
    --cell-color: #dcfce7;
    --text-dark: #1e293b;
    --primary: #4f46e5;
    --primary-hover: #4338ca;
    --tile-bg: #ffffff;
    --border-color: #000000;
    --shadow: 0 4px 6px rgba(0,0,0,0.1);
}

body.theme-bio {
    --bg-color: #dcfce7;
    --header-color: #86efac;
    --cell-color: #f0fdf4;
    --primary: #166534;
    --primary-hover: #14532d;
}

body.theme-chem {
    --bg-color: #dbeafe;
    --header-color: #93c5fd;
    --cell-color: #eff6ff;
    --primary: #1e40af;
    --primary-hover: #1e3a8a;
}

body.theme-phys {
    --bg-color: #f3e8ff;
    --header-color: #d8b4fe;
    --cell-color: #faf5ff;
    --primary: #581c87;
    --primary-hover: #4c1d95;
}

body.theme-math {
    --bg-color: #fee2e2;
    --header-color: #fca5a5;
    --cell-color: #fef2f2;
    --primary: #991b1b;
    --primary-hover: #7f1d1d;
}

body.theme-eng {
    --bg-color: #fef3c7;
    --header-color: #fcd34d;
    --cell-color: #fffbeb;
    --primary: #854d0e;
    --primary-hover: #713f12;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
    font-family: 'Inter', sans-serif;
    background-color: var(--bg-color);
    color: var(--text-dark);
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

.game-header {
    background-color: var(--primary);
    color: white;
    padding: 1.5rem;
    text-align: center;
    box-shadow: var(--shadow);
}

.game-header h1 { margin: 0.5rem 0; font-size: 1.8rem; }

.back-btn {
    position: absolute;
    top: 1.5rem; left: 1.5rem;
    color: white;
    text-decoration: none;
    font-weight: 600;
    background: rgba(255,255,255,0.2);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    transition: background 0.2s;
}

.back-btn:hover { background: rgba(255,255,255,0.3); }

/* In-game HUD */
.game-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 1rem;
    font-size: 1.2rem;
    font-weight: 600;
}

#game-timer, #game-mistakes {
    background: rgba(255, 255, 255, 0.2);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.3);
}

.game-container {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; padding: 2rem 1rem; gap: 2rem;
}

/* One Tile At A Time UI */
#one-tile-mode-container {
    width: 100%;
    max-width: 1100px;
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: var(--shadow);
    margin-bottom: 1.5rem;
}

.one-tile-board {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 4rem;
}

.current-tile-box, .upcoming-tile-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.current-tile-box h3, .upcoming-tile-box h3 {
    margin-bottom: 0.5rem;
    color: var(--primary);
    font-size: 1.1rem;
}

.tile.upcoming {
    background-color: #f8fafc;
    border-color: #cbd5e1;
    color: #64748b;
    cursor: default;
    transform: scale(0.9);
}

.tile.upcoming:hover {
    background-color: #f8fafc;
    color: #64748b;
}

.table-wrapper {
    width: 100%; max-width: 1100px;
    overflow-x: auto; padding-bottom: 1rem;
}

.grid-board { display: grid; gap: 8px; }

.grid-cell {
    background-color: var(--cell-color);
    border: 2px solid var(--border-color);
    border-radius: 6px; min-height: 80px;
    display: flex; align-items: center; justify-content: center;
    padding: 12px; text-align: center;
    font-weight: 600; font-size: 0.95rem;
    transition: background-color 0.2s, transform 0.2s;
}

.grid-header { background-color: var(--header-color); font-size: 1.05rem; }

.grid-empty-slot {
    background-color: rgba(220, 252, 231, 0.4);
    border: 2px dashed var(--border-color); cursor: pointer;
}

.grid-empty-slot:hover { background-color: rgba(220, 252, 231, 0.8); }

.tile-bank-container {
    width: 100%; max-width: 1100px;
    background: white; padding: 1.5rem;
    border-radius: 8px; box-shadow: var(--shadow);
}

.tile-bank-container h2 {
    margin-bottom: 1rem; font-size: 1.2rem;
    text-align: center; color: var(--primary);
}

.tile-bank {
    display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
}

.tile {
    background-color: var(--tile-bg);
    border: 2px solid var(--primary); color: var(--primary);
    border-radius: 6px; padding: 10px 15px;
    font-weight: 600; cursor: pointer; text-align: center;
    user-select: none; transition: all 0.2s; max-width: 250px;
}

.tile:hover { background-color: var(--primary); color: white; }

.tile.selected {
    background-color: var(--primary-hover); color: white;
    transform: scale(1.05); box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    border-color: var(--text-dark);
}

/* Modal styles */
.modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.6); display: none;
    align-items: center; justify-content: center; z-index: 1000;
}

.modal-content {
    background: white; padding: 3rem; border-radius: 8px;
    text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    animation: slideUp 0.3s ease-out forwards;
}

.modal-content h2 { color: var(--primary); margin-bottom: 1rem; font-size: 2rem; }

#loseModal h2 { color: #ef4444; }

.modal-content button, .modal-content .btn-secondary {
    display: inline-block; margin-top: 1.5rem;
    padding: 0.75rem 1.5rem; border: none; border-radius: 4px;
    font-size: 1rem; font-weight: 600; cursor: pointer; text-decoration: none;
}

.modal-content button { background: var(--primary); color: white; margin-right: 1rem; }
.modal-content button:hover { background: var(--primary-hover); }
.modal-content .btn-secondary { background: #e2e8f0; color: var(--text-dark); }
.modal-content .btn-secondary:hover { background: #cbd5e1; }

@keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    50% { transform: translateX(5px); }
    75% { transform: translateX(-5px); }
}

.shake { animation: shake 0.3s ease-in-out; border-color: #ef4444 !important; background-color: #fee2e2 !important; }
@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
@media (max-width: 768px) { .back-btn { position: static; display: inline-block; margin-bottom: 1rem; } }

/* --- Dark Theme Overrides --- */
:root.dark-theme, body.dark-theme {
    --bg-color: #0f172a;
    --text-dark: #f8fafc;
    --tile-bg: #1e293b;
    --cell-color: #334155;
    --header-color: var(--primary);
    --border-color: #64748b;
}

:root.dark-theme .tile, body.dark-theme .tile {
    color: var(--text-dark);
    border-color: var(--primary);
}

:root.dark-theme .tile.upcoming, body.dark-theme .tile.upcoming {
    background-color: #1e293b;
    border-color: #475569;
    color: #94a3b8;
}

:root.dark-theme #one-tile-mode-container, body.dark-theme #one-tile-mode-container,
:root.dark-theme .tile-bank-container, body.dark-theme .tile-bank-container,
:root.dark-theme .modal-content, body.dark-theme .modal-content {
    background: #1e293b;
    color: #f8fafc;
}

:root.dark-theme .grid-empty-slot, body.dark-theme .grid-empty-slot {
    background-color: rgba(51, 65, 85, 0.4);
}
:root.dark-theme .grid-empty-slot:hover, body.dark-theme .grid-empty-slot:hover {
    background-color: rgba(51, 65, 85, 0.8);
}
