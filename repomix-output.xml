<file path="games/chemistry/advanced/acid-alliance/style.css">
:root {
    --bg-color: #f1f5f9;
    --card-bg: #ffffff;
    --text-dark: #334155;
    --subject-primary: #1e40af;
    --subject-hover: #1e3a8a;
    --primary: #1e40af;
    --border-color: #e2e8f0;
    --danger: #ef4444;
    --success: #10b981;
    --shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.dark-theme {
    --bg-color: #0f172a;
    --card-bg: #1e293b;
    --text-dark: #f8fafc;
    --subject-primary: #3b82f6;
    --subject-hover: #2563eb;
    --primary: #3b82f6;
    --border-color: #334155;
}

body { background-color: var(--bg-color); }

.game-container {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; padding: 3rem 1rem; 
    max-width: 800px; margin: 0 auto; width: 100%;
}

.crisis-panel {
    background: var(--card-bg); padding: 2rem; border-radius: 12px;
    box-shadow: var(--shadow); width: 100%; margin-bottom: 2rem;
    border: 2px solid var(--border-color); border-top: 6px solid var(--danger);
}

.crisis-header {
    color: var(--danger); font-weight: 800; text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;
}

.crisis-text { font-size: 1.2rem; line-height: 1.6; margin-bottom: 2rem; }
.options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

.option-btn {
    background: var(--card-bg); border: 2px solid var(--primary);
    color: var(--text-dark); padding: 1rem; border-radius: 8px;
    font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.2s;
}

@media (hover: hover) { .option-btn:hover:not(:disabled) { background: var(--primary); color: white; } }

.option-btn.correct { background: var(--success); border-color: var(--success); color: white; }
.option-btn.wrong { background: var(--danger); border-color: var(--danger); color: white; animation: shake 0.3s; }
.option-btn:disabled { cursor: not-allowed; opacity: 0.8; }

@keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    50% { transform: translateX(5px); }
    75% { transform: translateX(-5px); }
}

@media (max-width: 600px) {
    .options-grid { grid-template-columns: 1fr; }
    .back-btn { position: static; display: inline-block; margin-bottom: 1rem; }
}
