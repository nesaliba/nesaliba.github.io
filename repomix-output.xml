import { BaseGame } from '/games/shared/base-game.js';

const ELEMENTS = [
    // Alkali Metals
    { name: "Lithium", sym: "Li", radius: "152 pm", ie: "520 kJ/mol", en: "0.98", category: "alkali", note: "Highly reactive metal, low density. Trend indicates top-left region." },
