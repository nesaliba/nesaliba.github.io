:root {
    --subject-primary: #991b1b;
    --subject-hover: #7f1d1d;
    --bg-color: #f8fafc;
    --panel-bg: #ffffff;
    --border-color: #cbd5e1;
    --text-dark: #1e293b;
    --cell-bg: #fef2f2;
    --corner-bg: #fca5a5;
}

body.dark-theme {
    --bg-color: #0f172a;
    --panel-bg: #1e293b;
    --border-color: #475569;
    --text-dark: #f8fafc;
    --cell-bg: #334155;
    --corner-bg: #7f1d1d;
}

body { background-color: var(--bg-color); }

.game-container { max-width: 900px; margin: 2rem auto; padding: 0 1rem; display: flex; flex-direction: column; gap: 1.5rem; }

.controls-panel {
    background: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 12px;
    padding: 1.5rem; display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: flex-end; justify-content: space-between;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.control-group { display: flex; flex-direction: column; flex: 1; min-width: 200px; }
.control-group label { font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark); }

.game-select {
    padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border-color);
    background: var(--bg-color); color: var(--text-dark); font-weight: 600; cursor: pointer;
}

.grid-panel {
    background: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 12px;
    padding: 1.5rem; box-shadow: 0 4px 6px rgba(0,0,0,0.1); display: flex; justify-content: center;
    overflow-x: auto;
}

.math-grid {
    display: grid;
    grid-template-columns: 80px repeat(4, minmax(100px, 1fr));
    gap: 8px;
    width: 100%;
}

.grid-header {
    background: var(--subject-primary);
    color: white; font-weight: 800; font-size: 1.4rem;
    display: flex; align-items: center; justify-content: center;
    border-radius: 8px; padding: 10px; text-align: center;
}

.grid-header.corner { background: var(--corner-bg); font-size: 1rem; color: var(--text-dark); }
body.dark-theme .grid-header.corner { color: white; }

.grid-cell {
    background: var(--cell-bg);
    border: 2px solid var(--border-color); border-radius: 8px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 8px; min-height: 80px; transition: all 0.2s; position: relative;
}

.grid-cell input {
    width: 100%; text-align: center; font-size: 1.5rem; font-weight: 800;
    border: 2px solid #cbd5e1; border-radius: 6px; outline: none;
    padding: 5px; background: white; color: #1e293b; transition: all 0.2s;
}

body.dark-theme .grid-cell input { background: #1e293b; color: #f8fafc; border-color: #475569; }

.grid-cell input:focus { border-color: var(--subject-primary); }
.grid-cell input:disabled { background: transparent; color: inherit; border-color: transparent; cursor: default; }

.active-tile {
    box-shadow: 0 0 15px 4px var(--subject-primary); border-color: var(--subject-primary);
    transform: scale(1.05); z-index: 10;
}

.solved-tile {
    background: #22c55e !important; border-color: #16a34a !important;
}
.solved-tile input { color: white !important; font-weight: 900; }

.bedmas-expr {
    font-size: 0.95rem; font-weight: 800; margin-bottom: 6px;
    color: var(--text-dark); text-align: center; white-space: nowrap;
}
.solved-tile .bedmas-expr { color: white; }

@keyframes shakeError {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    50% { transform: translateX(5px); }
    75% { transform: translateX(-5px); }
}
.shake { animation: shakeError 0.3s ease-in-out; border-color: #ef4444 !important; }

@media (max-width: 600px) {
    .math-grid { grid-template-columns: 60px repeat(4, minmax(80px, 1fr)); }
    .grid-cell input { font-size: 1.2rem; }
