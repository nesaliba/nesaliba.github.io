<file path="games/chemistry/advanced/quantum-architect/style.css">
:root {
    --qa-bg: #050a14;
    --qa-panel: rgba(10, 15, 30, 0.85);
    --qa-cyan: #00f0ff;
    --qa-cyan-dim: rgba(0, 240, 255, 0.2);
    --qa-amber: #ffb700;
    --qa-green: #00ff00;
    --qa-red: #dc2626;
    --qa-text: #e2e8f0;
}

body.dark-lab-theme {
    background-color: var(--qa-bg);
    color: var(--qa-text);
    font-family: 'Inter', sans-serif;
    margin: 0;
    padding: 0;
}

.qa-header {
    background: #0f172a;
    border-bottom: 2px solid var(--qa-cyan);
    box-shadow: 0 4px 20px var(--qa-cyan-dim);
}

.qa-header h1 {
    color: var(--qa-cyan);
    text-transform: uppercase;
    letter-spacing: 2px;
}

.qa-container {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
    max-width: 1300px;
    margin: 2rem auto;
    padding: 0 1rem;
    flex: 1;
}

@media (max-width: 1000px) {
    .qa-container {
        grid-template-columns: 1fr;
    }
}

.qa-panel {
    background: var(--qa-panel);
    border: 1px solid var(--qa-cyan);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: inset 0 0 15px var(--qa-cyan-dim);
    display: flex;
    flex-direction: column;
}

.qa-panel h2 {
    color: var(--qa-amber);
    margin-top: 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--qa-amber);
    padding-bottom: 0.5rem;
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* Evidence Styles */
.evidence-panel {
    max-height: 750px;
    overflow-y: auto;
}

.clue-box {
    border-left: 3px solid var(--qa-amber);
    padding-left: 1rem;
    margin-bottom: 1.5rem;
    background: rgba(255, 183, 0, 0.05);
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
}

.clue-title {
    color: var(--qa-cyan);
    font-weight: bold;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    font-size: 0.9rem;
}

.flame-container {
    background: #000;
    width: 60px;
    height: 80px;
    border-radius: 8px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 10px;
    margin: 0 auto;
    border: 1px solid #333;
}

.flame {
    width: 40px;
    height: 60px;
    border-radius: 50% 50% 20% 20%;
    filter: blur(2px);
    animation: flicker 0.15s infinite alternate;
}

@keyframes flicker {
    0% { transform: scaleY(1); opacity: 0.8; }
    100% { transform: scaleY(1.1); opacity: 1; }
}

.spectrum-strip {
    height: 35px;
    background: #000;
    position: relative;
    border: 1px solid #444;
    overflow: hidden;
}

.spec-line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
}

.ie-graph {
    display: flex;
    align-items: flex-end;
    height: 90px;
    gap: 4px;
    border-bottom: 1px solid var(--qa-text);
    border-left: 1px solid var(--qa-text);
    padding: 4px 4px 0 4px;
    margin-top: 0.5rem;
}

.ie-bar {
    width: 15px;
    transition: height 0.3s;
}

/* Builder Styles */
.bohr-diagram {
    position: relative;
    width: 300px;
    height: 300px;
    margin: 0 auto;
}

.bohr-nucleus {
    position: absolute;
    top: 50%; left: 50%;
    width: 30px; height: 30px;
    margin-top: -15px; margin-left: -15px;
    background: var(--qa-amber);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--qa-amber);
    z-index: 5;
}

.bohr-ring {
    position: absolute;
    top: 50%; left: 50%;
    border: 1px dashed var(--qa-cyan-dim);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    z-index: 1;
    pointer-events: none; /* rings themselves don't capture events */
}

.bohr-ring:hover {
    background: transparent;
    border-color: var(--qa-cyan);
}

.bohr-ring[data-shell="1"] { width: 80px;  height: 80px;  }
.bohr-ring[data-shell="2"] { width: 140px; height: 140px; }
.bohr-ring[data-shell="3"] { width: 200px; height: 200px; }
.bohr-ring[data-shell="4"] { width: 260px; height: 260px; }

.bohr-electron {
    position: absolute;
    width: 12px; height: 12px;
    background: var(--qa-cyan);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    cursor: pointer;
    box-shadow: 0 0 8px var(--qa-cyan);
    z-index: 10;
    transition: transform 0.1s;
}

.bohr-electron:hover { transform: translate(-50%, -50%) scale(1.5); }

.electron-pool {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
    min-height: 40px;
    border: 1px solid var(--qa-cyan-dim);
    padding: 10px;
    border-radius: 8px;
}

.pool-electron {
    width: 14px; height: 14px;
    background: var(--qa-cyan);
    border-radius: 50%;
    cursor: grab;
    box-shadow: 0 0 5px var(--qa-cyan);
}
.pool-electron:active { cursor: grabbing; }

/* Orbital Box Styles */
.orbital-board {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.subshell-row {
    display: flex;
    align-items: center;
    background: rgba(0, 0, 0, 0.3);
    padding: 0.5rem;
    border-radius: 4px;
}

.sub-label {
    width: 50px;
    color: var(--qa-amber);
    font-weight: bold;
    font-size: 1.1rem;
}

.btn-sub {
    background: transparent;
    border: 1px solid var(--qa-cyan);
    color: var(--qa-cyan);
    width: 28px;
    height: 28px;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
    transition: all 0.2s;
}

.btn-sub:hover:not(:disabled) {
    background: var(--qa-cyan);
    color: var(--qa-bg);
}
.btn-sub:disabled {
    border-color: #334155;
    color: #334155;
    cursor: not-allowed;
}

.orbital-boxes {
    display: flex;
    gap: 6px;
    margin: 0 1rem;
    flex: 1;
}

.orb-box {
    width: 24px;
    height: 24px;
    border: 1px solid var(--qa-text);
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 1rem;
    font-weight: bold;
    color: var(--qa-cyan);
    background: #000;
}

.arr-up, .arr-down { display: inline-block; width: 10px; text-align: center; }
.arr-down { color: var(--qa-amber); }

/* Periodic Table Styles */
.pt-panel {
    transition: opacity 0.3s;
}

.pt-panel.locked {
    opacity: 0.4;
    pointer-events: none;
}

.pt-grid {
    display: grid;
    grid-template-columns: repeat(18, 1fr);
    grid-template-rows: repeat(4, 1fr);
    gap: 3px;
    margin-top: 1rem;
}

.pt-cell {
    border: 1px solid var(--qa-cyan-dim);
    color: var(--qa-cyan);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: bold;
    cursor: pointer;
    height: 35px;
    transition: all 0.2s;
    background: rgba(0, 240, 255, 0.05);
}

.pt-cell:hover:not(.empty) {
    background: var(--qa-cyan);
    color: var(--qa-bg);
    transform: scale(1.1);
    z-index: 2;
    box-shadow: 0 0 10px var(--qa-cyan);
}

.pt-cell.empty {
    border-color: transparent;
    background: transparent;
    pointer-events: none;
}

.codex-box {
    border: 1px solid var(--qa-cyan);
    padding: 0.75rem;
    text-align: center;
    font-weight: bold;
    border-radius: 4px;
    background: rgba(0,0,0,0.5);
}

.codex-box.unlocked {
    color: var(--qa-bg);
    background: var(--qa-cyan);
    box-shadow: 0 0 10px var(--qa-cyan);
}
