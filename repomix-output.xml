<file path="games/chemistry/intermediate/gas-laws-gauntlet/style.css">
:root {
    --bg-color: #f1f5f9;
    --card-bg: #ffffff;
    --text-dark: #1e293b;
    --subject-primary: #0284c7;
    --subject-hover: #0369a1;
    --primary: #0284c7;
    --border-color: #cbd5e1;
    --danger: #ef4444;
    --warning: #f59e0b;
    --success: #10b981;
    --shadow: 0 4px 6px rgba(0,0,0,0.1);
    --metal-dark: #334155;
    --metal-light: #94a3b8;
    --glass: rgba(226, 232, 240, 0.4);
}

.dark-theme {
    --bg-color: #0f172a;
    --card-bg: #1e293b;
    --text-dark: #f8fafc;
    --subject-primary: #38bdf8;
    --subject-hover: #0ea5e9;
    --primary: #38bdf8;
    --border-color: #334155;
    --metal-dark: #0f172a;
    --metal-light: #475569;
    --glass: rgba(15, 23, 42, 0.6);
}

body { background-color: var(--bg-color); }

.game-container {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; padding: 2rem 1rem; 
    max-width: 950px; margin: 0 auto; width: 100%;
}

.crisis-panel {
    background: var(--card-bg); padding: 2rem; border-radius: 12px;
    box-shadow: var(--shadow); width: 100%; margin-bottom: 2rem;
    border: 2px solid var(--border-color); border-top: 6px solid var(--primary);
    position: relative; overflow: hidden;
}

.scenario-header {
    color: var(--primary); font-weight: 800; text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;
}

.scenario-text { font-size: 1.15rem; line-height: 1.6; margin-bottom: 1.5rem; font-weight: 600; color: var(--text-dark); }

/* Industrial Chamber UI */
.industrial-facility {
    display: flex; gap: 2rem; justify-content: space-between; align-items: stretch;
    background: var(--metal-dark); padding: 2rem; border-radius: 12px;
    margin-bottom: 2rem; border: 4px solid var(--metal-light);
    box-shadow: inset 0 10px 30px rgba(0,0,0,0.5); position: relative;
}

/* Chamber & Piston */
.chamber-wrapper {
    position: relative; width: 180px; height: 250px;
    background: var(--glass); border: 4px solid #64748b;
    border-radius: 8px; border-top: none; overflow: hidden;
    display: flex; flex-direction: column; justify-content: flex-end;
}

.chamber-walls-glow {
    position: absolute; inset: -4px; border: 4px solid transparent; border-top: none;
    border-radius: 8px; pointer-events: none; z-index: 10; transition: border-color 0.3s, box-shadow 0.3s;
}

.piston-assembly {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 5;
    pointer-events: none; overflow: hidden;
}

.piston-rod {
    position: absolute; left: 50%; transform: translateX(-50%);
    width: 20px; background: linear-gradient(90deg, #94a3b8, #cbd5e1, #94a3b8);
    top: 0; height: 0;
    border-radius: 4px 4px 0 0;
}

.piston-head {
    position: absolute; left: 0; width: 100%; height: 20px;
    background: linear-gradient(180deg, #64748b, #334155);
    border-radius: 4px; box-shadow: 0 4px 6px rgba(0,0,0,0.4);
}

.particle-canvas {
    position: absolute; bottom: 0; left: 0; width: 100%; height: 100%; z-index: 1;
}

/* Gauges */
.gauges-panel {
    display: flex; flex-direction: column; gap: 1.5rem; justify-content: center; flex: 1;
}

.gauge-container {
    background: var(--card-bg); padding: 1rem; border-radius: 8px;
    border: 2px solid var(--metal-light); text-align: center;
    box-shadow: 0 4px 6px rgba(0,0,0,0.2); position: relative;
}

.gauge-label { font-weight: 800; color: var(--text-dark); margin-bottom: 0.5rem; display: block; }
.gauge-value { font-size: 1.5rem; font-family: monospace; font-weight: bold; color: var(--primary); }

/* HUD Graph */
.hud-graph-container {
    background: #020617; padding: 1rem; border-radius: 8px; border: 2px solid #334155;
    margin-bottom: 2rem;
}
.hud-header { color: #38bdf8; font-size: 0.9rem; font-weight: bold; text-transform: uppercase; margin-bottom: 0.5rem; letter-spacing: 1px;}
.graph-canvas { width: 100%; height: 120px; background: #0f172a; border-radius: 4px; border: 1px solid #1e293b; }

/* Controls */
.controls-area {
    background: var(--details-bg); padding: 1.5rem; border-radius: 8px;
    border: 1px solid var(--border-color); text-align: center; margin-bottom: 1.5rem;
}

.controls-area label { display: block; font-weight: 700; margin-bottom: 1rem; color: var(--text-dark); font-size: 1.1rem; }
input[type="range"] { width: 100%; accent-color: var(--primary); cursor: pointer; height: 8px; }

/* Warning States */
.state-warning .chamber-walls-glow { border-color: var(--warning); box-shadow: 0 0 20px rgba(245, 158, 11, 0.5); }
.state-critical .chamber-walls-glow { border-color: var(--danger); box-shadow: 0 0 30px rgba(239, 68, 68, 0.8); }
.shake-severe { animation: shake-severe 0.2s infinite; }

@keyframes shake-severe {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(-3px, 2px); }
    50% { transform: translate(3px, -2px); }
    75% { transform: translate(-3px, -2px); }
}

/* Diagnostic Overlay */
.diagnostic-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.85); display: none; flex-direction: column;
    align-items: center; justify-content: center; color: white; z-index: 100;
    padding: 2rem; text-align: center; backdrop-filter: blur(4px);
    animation: fadeIn 0.3s ease-out;
}
.diagnostic-overlay.active { display: flex; }
.diagnostic-title { color: var(--danger); font-size: 1.8rem; font-weight: 800; margin-bottom: 1rem; }
.diagnostic-message { font-size: 1.1rem; margin-bottom: 1.5rem; line-height: 1.5; max-width: 500px; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* Reference Panel */
.reference-panel { background: var(--details-bg); border-radius: 8px; border: 1px solid var(--border-color); margin-bottom: 1.5rem; }
.reference-panel summary { padding: 1rem; font-weight: 700; cursor: pointer; color: var(--subject-primary); display: flex; justify-content: space-between; }
.reference-panel summary::-webkit-details-marker { display: none; }
.reference-panel summary::after { content: '+'; font-size: 1.2rem; }
.reference-panel[open] summary::after { content: '-'; }
.ref-content { padding: 1rem; border-top: 1px solid var(--border-color); font-size: 0.95rem; line-height: 1.6; }

@media (max-width: 700px) {
    .industrial-facility { flex-direction: column; align-items: center; }
    .gauges-panel { width: 100%; flex-direction: row; flex-wrap: wrap; }
    .gauge-container { flex: 1; min-width: 120px; }
}
</file>

