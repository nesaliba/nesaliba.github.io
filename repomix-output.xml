    --subject-primary: #854d0e;
    --subject-hover: #713f12;
    --text-dark: #1e293b;
    --monitor-bg: #020617;
    --monitor-text: #22c55e;
}

body.dark-theme {
    --bg-color: #0f172a;
    --panel-bg: #1e293b;
    --border-color: #475569;
    --text-dark: #f8fafc;
}

body { background-color: var(--bg-color); }

.game-container {
    display: flex; max-width: 1200px; margin: 2rem auto;
    gap: 2rem; padding: 0 1rem; align-items: flex-start;
}

.controls-panel {
    flex: 1; background: var(--panel-bg); padding: 1.5rem;
    border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border: 1px solid var(--border-color);
}

