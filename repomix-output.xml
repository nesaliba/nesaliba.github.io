<file path="games/social/advanced/sovereignty-standoff/style.css">
:root {
    --bg-color: #0f172a; /* Deep navy */
    --panel-bg: #1e293b; /* Charcoal */
    --border-color: #475569;
    --subject-primary: #0d9488;
    --subject-hover: #0f766e;
    --text-dark: #f8fafc;
    --amber: #f59e0b;
    --danger-red: #ef4444;
    --dossier-bg: #f8fafc;
    --dossier-text: #0f172a;
}

body.theme-soc {
    background-color: var(--bg-color);
    color: var(--text-dark);
}

.game-header {
    background-color: var(--panel-bg);
    border-bottom: 2px solid var(--subject-primary);
}

.tension-container {
    max-width: 400px;
    margin: 1rem auto 0 auto;
    text-align: center;
}

.tension-bar {
    width: 100%;
    height: 18px;
    background: #334155;
    border-radius: 4px;
    border: 2px solid #cbd5e1;
    overflow: hidden;
}

.tension-fill {
    height: 100%;
    background: var(--amber);
    transition: width 0.4s ease, background-color 0.4s ease;
}

.tension-fill.critical {
    background: var(--danger-red);
    box-shadow: 0 0 10px var(--danger-red);
}

.game-container {
    max-width: 900px; margin: 2rem auto; padding: 0 1rem;
    display: flex; flex-direction: column; gap: 1.5rem;
}

.arena-panel {
    background: var(--panel-bg); border: 1px solid var(--border-color);
    border-radius: 12px; padding: 1.5rem; box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

.dossier-container {
    background-color: var(--dossier-bg);
    color: var(--dossier-text);
    border: 1px solid #94a3b8;
    padding: 2.5rem;
    position: relative;
    font-family: 'Courier Prime', Courier, monospace;
    box-shadow: inset 0 0 20px rgba(0,0,0,0.05), 0 4px 6px rgba(0,0,0,0.1);
    min-height: 250px;
}

.dossier-container::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.03) 2px,
        rgba(0, 0, 0, 0.03) 4px
    );
    pointer-events: none;
}

.classified-stamp {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    color: var(--danger-red);
    border: 3px solid var(--danger-red);
    padding: 0.5rem 1rem;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 2px;
    transform: rotate(-12deg);
    opacity: 0.8;
    pointer-events: none;
}

.dossier-header {
    display: flex;
    justify-content: space-between;
    border-bottom: 2px solid var(--dossier-text);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
    font-weight: bold;
}

.prompt-text {
    font-size: 1.15rem;
    line-height: 1.6;
    white-space: pre-wrap;
}

.battle-panel {
    background: var(--panel-bg); border: 1px solid var(--border-color);
    border-radius: 12px; padding: 1.5rem; box-shadow: 0 4px 6px rgba(0,0,0,0.2);
}

.options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

.btn-option {
    padding: 1rem; font-size: 1rem; font-weight: 600; 
    background: #334155; color: #f8fafc; 
    border: 2px solid #64748b; border-radius: 8px; cursor: pointer;
    transition: all 0.2s; min-height: 90px; display: flex; align-items: center;
    justify-content: center; text-align: center; line-height: 1.4;
    font-family: 'Inter', sans-serif;
}

.btn-option:hover:not(:disabled) { 
    background: #475569; 
    transform: translateY(-2px); 
    box-shadow: 0 4px 10px rgba(0,0,0,0.3); 
    border-color: var(--subject-primary);
}

@media (max-width: 768px) { 
    .options-grid { grid-template-columns: 1fr; } 
    .classified-stamp { font-size: 1.2rem; top: 1rem; right: 1rem; }
    .dossier-container { padding: 1.5rem; }
}
</file>

