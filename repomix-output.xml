.enemy-hp-bar { width: 200px; height: 14px; background: #e2e8f0; border-radius: 7px; overflow: hidden; margin: 0 auto; border: 1px solid #94a3b8; }
.enemy-hp-fill { height: 100%; background: #ef4444; width: 100%; transition: width 0.3s ease-out; }

.battle-panel { background: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }

