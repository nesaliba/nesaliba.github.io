    --text-dark: #f8fafc;
    --blueprint-blue: #0ea5e9;
    --alarm-red: #ef4444;
    --safe-green: #22c55e;
}

body.blueprint-theme {
    background-color: var(--bg-color);
    background-image: linear-gradient(rgba(14, 165, 233, 0.1) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(14, 165, 233, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
}

.game-container { max-width: 900px; margin: 2rem auto; padding: 0 1rem; display: flex; flex-direction: column; gap: 1.5rem; }

.blueprint-panel {
    background: rgba(15, 23, 42, 0.9); border: 2px solid var(--blueprint-blue); border-radius: 12px;
    padding: 2.5rem; display: flex; justify-content: center; align-items: center; min-height: 250px;
    box-shadow: inset 0 0 50px rgba(14, 165, 233, 0.1); position: relative; overflow: hidden;
}

.heist-container { text-align: center; display: flex; flex-direction: column; align-items: center; }

.alarm-status {
    font-size: 1.2rem; font-weight: 800; color: var(--safe-green); margin-bottom: 1rem;
    letter-spacing: 2px; text-transform: uppercase;
}
.alarm-status.danger { color: var(--alarm-red); animation: pulse-text 1s infinite; }

.vault-graphic {
    width: 100px; height: 100px; border-radius: 50%;
    border: 4px dashed var(--blueprint-blue);
    display: flex; justify-content: center; align-items: center;
    position: relative; margin: 1rem 0;
    box-shadow: 0 0 20px rgba(14, 165, 233, 0.3);
}

.vault-graphic.danger { border-color: var(--alarm-red); box-shadow: 0 0 30px rgba(239, 68, 68, 0.5); }

.vault-wheel {
    width: 60px; height: 60px; border-radius: 50%;
    border: 4px solid var(--blueprint-blue);
    border-top-color: transparent; border-bottom-color: transparent;
    animation: spin 6s linear infinite;
}
.vault-graphic.danger .vault-wheel { border-color: var(--alarm-red); border-top-color: transparent; border-bottom-color: transparent; animation: spin 2s linear infinite; }

.status-text { font-size: 1rem; font-weight: 600; color: var(--blueprint-blue); margin-top: 1rem; font-family: monospace; }
.heist-container.danger .status-text { color: var(--alarm-red); }

.battle-panel { background: var(--panel-bg); border: 1px solid var(--blueprint-blue); border-radius: 12px; padding: 1.5rem; box-shadow: 0 4px 15px rgba(0,0,0,0.5); }

.prompt-container {
    width: 100%; min-height: 80px; display: flex; align-items: left; justify-content: left;
    background: rgba(2, 6, 23, 0.8); border: 1px solid var(--blueprint-blue); border-radius: 8px;
    margin-bottom: 1.5rem; padding: 1.5rem; color: var(--text-dark); font-size: clamp(1rem, 3.5vw, 1.25rem);
    font-weight: 600; text-align: center; overflow-x: auto; box-sizing: border-box;
}

.options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

.btn-option {
    padding: 1rem; font-size: clamp(0.9rem, 2.5vw, 1.15rem); font-weight: 600;
    background: #1e293b; color: #f8fafc; border: 2px solid #334155; border-radius: 8px;
    cursor: pointer; transition: all 0.2s; min-height: 80px;
    display: flex; align-items: center; justify-content: center; overflow-x: auto; word-wrap: break-word;
}

.btn-option:hover:not(:disabled) { background: #334155; border-color: var(--blueprint-blue); transform: translateY(-2px); box-shadow: 0 4px 10px rgba(14, 165, 233, 0.2); }

@keyframes spin { 100% { transform: rotate(360deg); } }
@keyframes pulse-text { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

@media (max-width: 768px) { .options-grid { grid-template-columns: 1fr; } }
