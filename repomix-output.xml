<file path="games/biology/advanced/reproduction-rift/style.css">
/* Dark Bioluminescent Theme */
:root, body.theme-rift {
    --bg-navy: #0B1021;
    --bg-panel: #131A32;
    --glow-teal: #00F0FF;
    --glow-magenta: #FF0055;
    --text-light: #E2E8F0;
    --border-dark: #2A365C;
    background-color: var(--bg-navy);
    color: var(--text-light);
    margin: 0;
    overflow-x: hidden;
}

.rift-header {
    background: #070B19;
    padding: 1.5rem;
    text-align: center;
    position: relative;
    border-bottom: 2px solid var(--glow-teal);
    box-shadow: 0 4px 20px rgba(0, 240, 255, 0.15);
}

.glow-text-teal {
    color: var(--glow-teal);
    text-shadow: 0 0 10px rgba(0, 240, 255, 0.6);
    margin: 0.5rem 0;
}

.glow-text-magenta {
    color: var(--glow-magenta);
    text-shadow: 0 0 10px rgba(255, 0, 85, 0.6);
    margin-bottom: 1rem;
}

.glow-btn {
    background: rgba(0, 240, 255, 0.1) !important;
    border: 1px solid var(--glow-teal);
    color: var(--glow-teal) !important;
    transition: all 0.3s ease;
}
.glow-btn:hover {
    background: rgba(0, 240, 255, 0.3) !important;
    box-shadow: 0 0 15px var(--glow-teal);
}

.game-stats-rift {
    display: flex; justify-content: center; gap: 1.5rem;
    margin-top: 1rem; flex-wrap: wrap; font-size: 1.1rem;
}

.stat-box-rift {
    background: var(--bg-panel); padding: 0.5rem 1rem;
    border-radius: 8px; font-weight: 600; border: 1px solid var(--border-dark);
    color: var(--text-light);
}

.stars { color: #FFD700; text-shadow: 0 0 8px rgba(255, 215, 0, 0.6); letter-spacing: 2px;}

.progress-bar-container {
    width: 80%; max-width: 600px; height: 10px;
    background: var(--bg-panel); border-radius: 5px;
    margin: 1.5rem auto 0; border: 1px solid var(--border-dark);
    overflow: hidden;
}

.progress-fill {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, var(--glow-teal), var(--glow-magenta));
    box-shadow: 0 0 10px var(--glow-teal);
    transition: width 0.5s ease-out;
}

.rift-container {
    display: flex; flex-direction: column; gap: 1.5rem;
    padding: 2rem 1.5rem; max-width: 1000px; margin: 0 auto;
    position: relative; flex: 1;
}

.scenario-panel-rift {
    background: var(--bg-panel); padding: 2rem;
    border-radius: 12px; text-align: center;
    border: 1px solid var(--border-dark);
    box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
    position: relative; z-index: 2;
}

.scenario-text { font-size: 1.2rem; line-height: 1.6; }

.interactive-area-rift {
    display: flex; flex-direction: column; gap: 1rem; z-index: 2;
}

/* Red Pulse Animation for Incorrect Answers */
@keyframes red-pulse {
    0% { background-color: var(--bg-navy); }
    50% { background-color: rgba(255, 0, 0, 0.4); }
    100% { background-color: var(--bg-navy); }
}
.red-pulse { animation: red-pulse 0.6s ease-in-out; }

/* Rift Healing Animation */
.rift-healing-overlay {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; z-index: 10;
}
.rift-healing-overlay.healing { animation: heal-flash 2.5s ease-in-out forwards; }

.healing-core {
    width: 50px; height: 50px; border-radius: 50%;
    background: var(--glow-teal);
    box-shadow: 0 0 50px 20px var(--glow-teal), 0 0 100px 40px var(--glow-magenta);
}

@keyframes heal-flash {
    0% { opacity: 0; transform: scale(0.5); }
    20% { opacity: 1; transform: scale(1.5); }
    80% { opacity: 1; transform: scale(2.5); box-shadow: 0 0 200px 100px var(--glow-teal); }
    100% { opacity: 0; transform: scale(3); }
}

/* Choices Styles */
.choice-btn {
    background: rgba(0, 240, 255, 0.05);
    border: 1px solid var(--border-dark);
    color: var(--text-light);
    padding: 1rem; border-radius: 8px; font-size: 1.1rem;
    cursor: pointer; transition: all 0.2s; text-align: left;
}
.choice-btn:hover {
    background: rgba(0, 240, 255, 0.15);
