export const gameData = {
    title: "Periodic Table Groups",
    backUrl: "/Chemistry.html",
    minWidth: 900, // Optimal for 4 data columns with larger text
    columns: ["", "Alkali Metals", "Halogens", "Alkaline Earth Metals", "Noble Gases"],
